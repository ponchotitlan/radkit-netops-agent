# =============================================================================
# Month of Smart Connections
# Ep.4: Intentions Matter
# MCP Hub environment template
#
# This file configures MCP services in docker-compose.yml.
# 1) Copy to .env
# 2) Fill required values
# 3) Keep .env out of git
# =============================================================================

# -----------------------------------------------------------------------------
# NetBox MCP
# -----------------------------------------------------------------------------
# Upstream NetBox API endpoint reachable from containers.
NETBOX_URL=http://host.docker.internal:8080

# NetBox API token (also reused by pyATS vault integration).
NETBOX_TOKEN=your_generated_token_here

# NetBox MCP listener settings.
NETBOX_MCP_HOST=0.0.0.0
NETBOX_MCP_PORT=8081

# Optional NetBox MCP tuning.
# NETBOX_MCP_LOG_LEVEL=INFO
# NETBOX_MCP_VERIFY_SSL=true


# -----------------------------------------------------------------------------
# RADKit MCP
# -----------------------------------------------------------------------------
# Container identity and listener settings.
RADKIT_FASTMCP_HOST=0.0.0.0
RADKIT_MCP_PORT=8082
RADKIT_MCP_HOST_PORT=8082

# RADKit runtime behavior.
RADKIT_SANDBOX=subprocess
RADKIT_ACCESS_MODE=direct
RADKIT_AUTO_APPROVE=true
RADKIT_RESTART_POLICY=unless-stopped

# Paths mounted from the repo into the container.
RADKIT_SERVICE_CONFIG=radkit-mcp/service.config.direct
RADKIT_PROFILE=radkit-mcp/radkit-mcp-profile.py
RADKIT_PROMPT_FILE=radkit-mcp/radkit-mcp-prompt.txt

# Log configuration.
RADKIT_LOGS_HOST_DIR=./radkit-mcp/logs



# -----------------------------------------------------------------------------
# GitHub MCP
# -----------------------------------------------------------------------------
# Fine-grained PAT: https://github.com/settings/tokens
GITHUB_PAT=your_generated_token_here

# GitHub MCP listener settings.
GITHUB_MCP_HOST=0.0.0.0
GITHUB_MCP_PORT=8083

# Toolsets to expose (comma-separated).
# Available: repos, issues, pull_requests, actions, code_security, projects, discussions, users, search, notifications
GITHUB_TOOLSETS=repos,issues,pull_requests,actions

# Optional GitHub Enterprise hostname.
# GITHUB_HOST=github.your-company.com

# -----------------------------------------------------------------------------
# DrawIO MCP
# -----------------------------------------------------------------------------
# DrawIO MCP listener settings.
DRAWIO_MCP_HOST=0.0.0.0
DRAWIO_MCP_PORT=8084
